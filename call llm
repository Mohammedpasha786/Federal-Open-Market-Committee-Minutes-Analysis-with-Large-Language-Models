function answer = call_llm(system_prompt, user_prompt, config)
%CALL_LLM  Send a chat completion request to the configured LLM.
%
%   answer = call_llm(system_prompt, user_prompt, config)
%
%   config fields used:
%       .llm_api_key  - OpenAI API key (or compatible)
%       .llm_model    - model string, e.g. 'gpt-4o'

    body = jsonencode(struct( ...
        'model',    config.llm_model, ...
        'messages', {{ ...
            struct('role','system','content', system_prompt), ...
            struct('role','user',  'content', user_prompt)   ...
        }}, ...
        'temperature', 0.2, ...
        'max_tokens',  1024));

    opts = weboptions( ...
        'HeaderFields', { ...
            'Authorization', ['Bearer ', config.llm_api_key]; ...
            'Content-Type',  'application/json'}, ...
        'MediaType',    'application/json', ...
        'RequestMethod','post', ...
        'Timeout', 60);

    try
        resp   = webwrite('https://api.openai.com/v1/chat/completions', body, opts);
        answer = resp.choices(1).message.content;
    catch ME
        answer = sprintf('[LLM error] %s', ME.message);
    end
end
